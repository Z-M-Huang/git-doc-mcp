{
  "name": "git-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Turn any manifest URL into a fully-functional MCP server",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build -w @git-mcp/core && npm run build -w git-mcp",
    "test": "npm run test -ws",
    "lint": "npm run lint -ws",
    "clean": "npm run clean -ws",
    "dev": "npm run dev -ws"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
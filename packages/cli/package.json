{
  "name": "git-doc-mcp",
  "version": "0.1.0",
  "description": "CLI for git-doc-mcp - turn any manifest into an MCP server",
  "type": "module",
  "bin": {
    "git-doc-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
